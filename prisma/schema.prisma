generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Campaign {
  id                  String           @id @default(cuid())
  name                String
  campaignType        String           @default("clipping")
  cpm                 Float            @default(0)
  maxPerClip          Float            @default(0)
  minPayout           Float            @default(0)
  paymentModel        String           @default("cpm")
  aiInstructions      String           @default("")
  contentRules        String           @default("")
  rejectionReasons    String           @default("")
  captionRules        String           @default("")
  platforms           String           @default("")
  taggingJson         String           @default("{}")
  submissionProcess   String           @default("")
  clipCount           Int              @default(10)
  variationsPerClip   Int              @default(1)          // 1-3: render N versions of each moment (different hook + title style)
  clipLength          Int              @default(60)
  clipLengthMin       Int              @default(30)
  clipLengthMax       Int              @default(90)
  extraContext        String           @default("")
  subtitlesEnabled    Boolean          @default(true)
  captionPresetId     String           @default("")
  captionMode         String           @default("lines")    // lines | word — "One Word" karaoke mode
  minVirality         String           @default("medium")  // all | medium | high — drop clips below this
  tightEdit           Boolean          @default(true)       // trim dead air for tighter pacing
  motionEnabled       Boolean          @default(true)       // Ken Burns push-in motion (crop layout)
  videoLayout         String           @default("letterbox") // letterbox | blur | crop | split (gameplay)
  captionPosition     String           @default("auto")     // auto | top | middle | bottom
  watermarkText       String           @default("")         // @handle overlay; empty = none
  bottomBanner        String           @default("")         // persistent brand CTA banner (last word highlighted); empty = none
  accountWarning      String           @default("")         // non-empty = this campaign needs a dedicated/new posting account
  aspectRatio         String           @default("9:16")
  scheduleEnabled     Boolean          @default(false)
  scheduleFrequency   String?
  scheduleTime        String?
  minimumEngagement   String           @default("")
  audienceRequirement String           @default("")
  postDuration        String           @default("")
  status              String           @default("active")
  createdAt           DateTime         @default(now())
  sources             CampaignSource[]
  jobs                AgentJob[]
}

model CampaignSource {
  id         String   @id @default(cuid())
  campaignId String
  platform   String
  url        String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
}

model SourceVideo {
  id         String   @id @default(cuid())
  campaignId String
  platform   String
  url        String
  videoId    String
  title      String
  duration   Int      @default(0)
  viewCount  Int      @default(0)
  uploadDate String   @default("")
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}

model AgentJob {
  id          String    @id @default(cuid())
  campaignId  String
  status      String    @default("idle")
  startedAt   DateTime?
  completedAt DateTime?
  logEntries  String    @default("[]")
  createdAt   DateTime  @default(now())
  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  clips       Clip[]
}

model Clip {
  id            String   @id @default(cuid())
  jobId         String
  campaignId    String
  title         String
  filePath      String
  downloadUrl   String
  thumbnailUrl  String   @default("")
  startTime     Float
  endTime       Float
  viralityScore String
  reason        String
  hook          String   @default("")
  caption       String   @default("")
  platformFit   String   @default("")
  status        String   @default("pending")
  postedAt      DateTime?
  createdAt     DateTime @default(now())
  job           AgentJob @relation(fields: [jobId], references: [id])
}

model SocialAccount {
  id           String    @id @default(cuid())
  platform     String    // "tiktok" | "instagram"
  accountName  String    @default("")
  accountId    String    @default("")
  accessToken  String
  refreshToken String    @default("")
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
}

// A posted clip the user is tracking — log its views to learn which hooks/styles pop.
model TrackedPost {
  id        String   @id @default(cuid())
  platform  String   @default("tiktok")   // tiktok | instagram | youtube | twitter
  url       String   @default("")
  hook      String   @default("")          // the on-screen hook used (so we can rank hooks)
  style     String   @default("")          // optional title style id
  views     Int      @default(0)
  likes     Int      @default(0)
  postedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostLog {
  id        String    @id @default(cuid())
  clipId    String
  platform  String
  status    String    @default("pending")
  postUrl   String    @default("")
  error     String    @default("")
  postedAt  DateTime?
  createdAt DateTime  @default(now())
}

model UserSettings {
  id              String @id @default("default")
  tiktokHandle    String @default("")
  instagramHandle String @default("")
  youtubeHandle   String @default("")
  kickHandle      String @default("")
  twitchHandle    String @default("")
  defaultLength   Int    @default(60)
  defaultRatio    String @default("9:16")
  subtitleStyle   String @default("viral-word")
  colorGrade      String @default("viral")
  autoEdit        Boolean @default(true)
  outputFolder    String @default("/tmp/clipflow")
  maxClipsPerVideo Int   @default(10)
  tiktokClientKey    String @default("")
  tiktokClientSecret String @default("")
  metaAppId          String @default("")
  metaAppSecret      String @default("")
  youtubeApiKey      String @default("")
  higgsfieldKey      String @default("")
  higgsfieldSecret   String @default("")
}
